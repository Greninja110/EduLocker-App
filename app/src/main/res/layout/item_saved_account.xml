<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card_dark"
    android:padding="16dp">

    <!-- Top row: avatar + info + active/switch -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Role initial badge -->
        <TextView
            android:id="@+id/tv_role_badge"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_circle_primary"
            android:layout_marginEnd="12dp" />

        <!-- Name + email + role -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_display_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tv_role_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAFFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="1dp" />

        </LinearLayout>

        <!-- Active badge -->
        <TextView
            android:id="@+id/tv_active_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● Active"
            android:textColor="@color/verified_green"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Switch button -->
        <TextView
            android:id="@+id/btn_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Switch"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/bg_rounded_primary"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#22FFFFFF"
        android:layout_marginVertical="10dp" />

    <!-- Bottom row: alias hint + edit + delete -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_alias_hint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#88FFFFFF"
            android:textSize="12sp"
            android:text="No alias set" />

        <TextView
            android:id="@+id/btn_edit_alias"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit Alias"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:paddingHorizontal="8dp"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/btn_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delete"
            android:textColor="#FF5252"
            android:textSize="12sp"
            android:paddingHorizontal="8dp"
            android:background="?attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

</LinearLayout>
