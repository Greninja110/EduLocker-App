<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/layout_settings_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

    <!-- Settings header — same dark-card style as Virtual ID Card -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_dark"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp">
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            android:tint="@color/white"
            android:padding="4dp"
            android:layout_marginEnd="12dp"
            android:background="?attr/selectableItemBackgroundBorderless" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/white" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Removed "Settings" title — now in header above -->

            <!-- User profile row -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:id="@+id/row_user_profile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:src="@mipmap/ic_launcher"
                        android:layout_marginEnd="16dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_user_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Student Name"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/tv_user_role"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Student Account"
                            android:textSize="13sp"
                            android:textColor="@color/primary" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Settings items card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <LinearLayout android:id="@+id/row_account_details"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:orientation="horizontal" android:paddingHorizontal="20dp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp"
                            android:src="@drawable/ic_profile" android:layout_marginEnd="16dp"
                            android:tint="@color/text_primary" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Account Details" android:textSize="15sp"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <LinearLayout android:id="@+id/row_privacy"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:orientation="horizontal" android:paddingHorizontal="20dp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp"
                            android:src="@drawable/ic_document" android:layout_marginEnd="16dp"
                            android:tint="@color/text_primary" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Privacy Settings" android:textSize="15sp"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <LinearLayout android:id="@+id/row_personalization"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:orientation="horizontal" android:paddingHorizontal="20dp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp"
                            android:src="@drawable/ic_home" android:layout_marginEnd="16dp"
                            android:tint="@color/text_primary" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Personalization &amp; Display" android:textSize="15sp"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <LinearLayout android:id="@+id/row_accessibility"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:orientation="horizontal" android:paddingHorizontal="20dp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp"
                            android:src="@drawable/ic_news" android:layout_marginEnd="16dp"
                            android:tint="@color/text_primary" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Accessibility" android:textSize="15sp"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <LinearLayout android:id="@+id/row_content_privacy"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:orientation="horizontal" android:paddingHorizontal="20dp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp"
                            android:src="@drawable/ic_document" android:layout_marginEnd="16dp"
                            android:tint="@color/text_primary" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Content Privacy" android:textSize="15sp"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <LinearLayout android:id="@+id/row_permissions"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:orientation="horizontal" android:paddingHorizontal="20dp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp"
                            android:src="@drawable/ic_search" android:layout_marginEnd="16dp"
                            android:tint="@color/text_primary" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="App Permissions" android:textSize="15sp"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <LinearLayout android:id="@+id/row_parent_control"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:orientation="horizontal" android:paddingHorizontal="20dp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp"
                            android:src="@drawable/ic_profile" android:layout_marginEnd="16dp"
                            android:tint="@color/text_primary" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Parent Control &amp; Tools" android:textSize="15sp"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <LinearLayout android:id="@+id/row_help"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:orientation="horizontal" android:paddingHorizontal="20dp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp"
                            android:src="@drawable/ic_news" android:layout_marginEnd="16dp"
                            android:tint="@color/text_primary" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Help &amp; Support" android:textSize="15sp"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <LinearLayout android:id="@+id/row_policy"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:orientation="horizontal" android:paddingHorizontal="20dp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp"
                            android:src="@drawable/ic_document" android:layout_marginEnd="16dp"
                            android:tint="@color/text_primary" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Privacy Policy incl. T&amp;C" android:textSize="15sp"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Created by card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:orientation="horizontal" android:paddingHorizontal="20dp"
                        android:gravity="center_vertical">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp"
                            android:src="@drawable/ic_profile" android:layout_marginEnd="16dp"
                            android:tint="@color/text_primary" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Created by"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary" />
                            <TextView
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Abhijeet Sahoo"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Add Account + Logout card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <LinearLayout
                        android:id="@+id/row_accounts"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:orientation="horizontal" android:paddingHorizontal="20dp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp"
                            android:src="@drawable/ic_profile" android:layout_marginEnd="16dp"
                            android:tint="@color/text_primary" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Saved Accounts" android:textSize="15sp"
                                android:textColor="@color/text_primary" />
                            <TextView android:id="@+id/tv_account_count"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_logout"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Log out"
                        android:textSize="15sp"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:paddingHorizontal="20dp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    </LinearLayout>

</FrameLayout>
