<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<androidx.core.widget.NestedScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="12dp">

        <!-- Top profile header — rounded card with margin on all 4 sides -->
        <LinearLayout
            android:id="@+id/layout_profile_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card_dark"
            android:padding="20dp"
            android:orientation="vertical">

            <!-- Settings icon row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Verified User" android:textColor="#AAFFFFFF"
                    android:textSize="12sp" android:layout_weight="1" />
                <ImageView android:id="@+id/iv_settings"
                    android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_settings"
                    android:tint="@color/white"
                    android:padding="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>

            <de.hdodenhof.circleimageview.CircleImageView
                android:layout_width="72dp" android:layout_height="72dp"
                android:src="@mipmap/ic_launcher"
                android:layout_marginTop="12dp" android:layout_marginBottom="8dp" />

            <TextView android:id="@+id/tv_student_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Student Name" android:textColor="@color/white"
                android:textSize="20sp" android:textStyle="bold" />

            <TextView android:id="@+id/tv_passport_id"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Passport ID: —"
                android:textColor="#CCFFFFFF" android:textSize="12sp"
                android:layout_marginTop="4dp" />

            <TextView android:id="@+id/tv_school_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Organisation" android:textColor="#CCFFFFFF"
                android:textSize="12sp" android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Details card — same rounded style, margin on all 4 sides -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_card_dark"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:id="@+id/tv_user_id"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="User ID:" android:textColor="#CCFFFFFF" android:textSize="12sp" />
                <TextView android:id="@+id/tv_verified_badge"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✓ Verified"
                    android:textColor="@color/verified_green" android:textSize="12sp"
                    android:textStyle="bold" android:visibility="gone" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#33FFFFFF" android:layout_marginVertical="8dp" />

            <!-- Tabular key-value rows -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingVertical="3dp">
                <TextView android:layout_width="114dp" android:layout_height="wrap_content"
                    android:text="KYC Status" android:textColor="#AAFFFFFF" android:textSize="13sp" />
                <TextView android:id="@+id/tv_kyc_status"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="#CCFFFFFF" android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingVertical="3dp">
                <TextView android:layout_width="114dp" android:layout_height="wrap_content"
                    android:text="S/D of" android:textColor="#AAFFFFFF" android:textSize="13sp" />
                <TextView android:id="@+id/tv_father_name"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="#CCFFFFFF" android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingVertical="3dp">
                <TextView android:layout_width="114dp" android:layout_height="wrap_content"
                    android:text="D.O.B" android:textColor="#AAFFFFFF" android:textSize="13sp" />
                <TextView android:id="@+id/tv_dob"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="#CCFFFFFF" android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingVertical="3dp">
                <TextView android:layout_width="114dp" android:layout_height="wrap_content"
                    android:text="Blood Group" android:textColor="#AAFFFFFF" android:textSize="13sp" />
                <TextView android:id="@+id/tv_blood_group"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="#CCFFFFFF" android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingVertical="3dp">
                <TextView android:layout_width="114dp" android:layout_height="wrap_content"
                    android:text="Contact" android:textColor="#AAFFFFFF" android:textSize="13sp" />
                <TextView android:id="@+id/tv_contact"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="#CCFFFFFF" android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingVertical="3dp">
                <TextView android:layout_width="114dp" android:layout_height="wrap_content"
                    android:text="Address" android:textColor="#AAFFFFFF" android:textSize="13sp" />
                <TextView android:id="@+id/tv_address"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="#CCFFFFFF" android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingVertical="3dp">
                <TextView android:layout_width="114dp" android:layout_height="wrap_content"
                    android:text="Pin Code" android:textColor="#AAFFFFFF" android:textSize="13sp" />
                <TextView android:id="@+id/tv_pin_code"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="#CCFFFFFF" android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingVertical="3dp">
                <TextView android:layout_width="114dp" android:layout_height="wrap_content"
                    android:text="Class" android:textColor="#AAFFFFFF" android:textSize="13sp" />
                <TextView android:id="@+id/tv_class"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="#CCFFFFFF" android:textSize="13sp" />
            </LinearLayout>

            <ImageView android:id="@+id/iv_qr_code"
                android:layout_width="80dp" android:layout_height="80dp"
                android:layout_marginTop="12dp"
                android:layout_gravity="end" />

            <!-- KYC verification button — hidden once already verified -->
            <Button
                android:id="@+id/btn_get_verified"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:text="Get ID Verified"
                android:background="@drawable/bg_gradient_primary"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:visibility="gone" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_view_id_card"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:text="View Virtual ID Card"
            android:background="@drawable/bg_gradient_primary"
            android:textColor="@color/white"
            android:textAllCaps="false" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
