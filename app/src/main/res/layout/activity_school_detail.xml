<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_card_dark"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp">
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            android:tint="@color/white"
            android:padding="4dp"
            android:layout_marginEnd="12dp"
            android:background="?attr/selectableItemBackgroundBorderless" />
        <TextView
            android:id="@+id/tv_toolbar_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Organisation Details"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Identity card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card_dark"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Registered Organisation"
                        android:textColor="#AAFFFFFF"
                        android:textSize="12sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓ Active"
                        android:textColor="@color/verified_green"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <de.hdodenhof.circleimageview.CircleImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@mipmap/ic_launcher"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_school_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_district"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tv_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AAFFFFFF"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Details card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card_dark"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Organisation Info"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#33FFFFFF"
                    android:layout_marginVertical="8dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingVertical="3dp">
                    <TextView android:layout_width="114dp" android:layout_height="wrap_content"
                        android:text="Org Code" android:textColor="#AAFFFFFF" android:textSize="13sp" />
                    <TextView android:id="@+id/tv_school_code"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:textColor="#CCFFFFFF" android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingVertical="3dp">
                    <TextView android:layout_width="114dp" android:layout_height="wrap_content"
                        android:text="Login Email" android:textColor="#AAFFFFFF" android:textSize="13sp" />
                    <TextView android:id="@+id/tv_email"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:textColor="#CCFFFFFF" android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingVertical="3dp">
                    <TextView android:layout_width="114dp" android:layout_height="wrap_content"
                        android:text="Principal" android:textColor="#AAFFFFFF" android:textSize="13sp" />
                    <TextView android:id="@+id/tv_principal"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:textColor="#CCFFFFFF" android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingVertical="3dp">
                    <TextView android:layout_width="114dp" android:layout_height="wrap_content"
                        android:text="Address" android:textColor="#AAFFFFFF" android:textSize="13sp" />
                    <TextView android:id="@+id/tv_address"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:textColor="#CCFFFFFF" android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingVertical="3dp">
                    <TextView android:layout_width="114dp" android:layout_height="wrap_content"
                        android:text="Students" android:textColor="#AAFFFFFF" android:textSize="13sp" />
                    <TextView android:id="@+id/tv_student_count"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:textColor="#CCFFFFFF" android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingVertical="3dp">
                    <TextView android:layout_width="114dp" android:layout_height="wrap_content"
                        android:text="Faculty" android:textColor="#AAFFFFFF" android:textSize="13sp" />
                    <TextView android:id="@+id/tv_teacher_count"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:textColor="#CCFFFFFF" android:textSize="13sp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
