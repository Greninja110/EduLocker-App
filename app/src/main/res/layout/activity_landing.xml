<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@mipmap/ic_launcher"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="welcome to edulocker"
        android:textSize="20sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="48dp" />

    <Button
        android:id="@+id/btn_login"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/login_existing"
        android:background="@drawable/bg_gradient_primary"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_register"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/register_new"
        style="@style/Widget.EduLocker.Button.Outlined"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tv_rescue_account"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/rescue_account"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:paddingVertical="8dp" />

</LinearLayout>
