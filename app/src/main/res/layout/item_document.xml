<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/surface">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
        <ImageView android:layout_width="36dp" android:layout_height="36dp"
            android:src="@drawable/ic_document" android:tint="@color/primary"
            android:layout_marginEnd="12dp" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tv_doc_title" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="14sp"
                android:textStyle="bold" android:textColor="@color/text_primary" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:id="@+id/tv_doc_type" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="12sp"
                    android:textColor="@color/text_secondary" />
                <TextView android:id="@+id/tv_doc_year" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="12sp"
                    android:textColor="@color/text_secondary" android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>
        <TextView android:id="@+id/tv_verified" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="✓ Verified"
            android:textSize="11sp" android:textColor="@color/verified_green"
            android:background="@color/card_achievement" android:paddingHorizontal="8dp"
            android:paddingVertical="4dp" android:layout_marginEnd="8dp" />
        <ImageView android:id="@+id/iv_delete"
            android:layout_width="32dp" android:layout_height="32dp"
            android:src="@drawable/ic_delete"
            android:tint="@color/error_red"
            android:padding="4dp"
            android:visibility="gone"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Delete" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
